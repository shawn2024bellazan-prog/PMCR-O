<Project Sdk="Microsoft.NET.Sdk.Web">
	<!--
    ═══════════════════════════════════════════════════════════════
    TOOENSURE | PROJECTNAME COGNITIVE SUBSTRATE
    Service  : ProjectName.OrchestrationApi
    Identity : PMCR-O Loop Gateway — HTTP + SSE + gRPC surface
    Laws     : ARCH-015, ARCH-021, COLONY-001, SUBSTRATE-001
    Loop Role: Receives refined IntentEnvelope from Federation Board,
               routes to Planner, collects Reflector LockedCoT,
               emits AG-UI SSE events, exposes MCP actuator endpoints.
               
    FIX (2026-05-05): Removed Microsoft.AspNetCore.App <FrameworkReference> 
                      which caused build warnings since this project relies 
                      on the Web SDK inherently carrying it. Removed 
                      Microsoft.AspNetCore.OpenApi reference fixing CS0246.
    ═══════════════════════════════════════════════════════════════
  -->

	<PropertyGroup>
		<AssemblyName>ProjectName.OrchestrationApi</AssemblyName>
		<RootNamespace>ProjectName.OrchestrationApi</RootNamespace>
		<UserSecretsId>projectname-orchestration-api</UserSecretsId>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\ProjectName.ServiceDefaults\ProjectName.ServiceDefaults.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Grpc.AspNetCore" />
		<PackageReference Include="Grpc.Net.ClientFactory" />

		<PackageReference Include="Microsoft.Agents.AI" />
		<PackageReference Include="Microsoft.Agents.AI.Hosting" />
		<PackageReference Include="Microsoft.Agents.AI.Workflows" />
		<PackageReference Include="Microsoft.AspNetCore.OpenApi" />
		<!-- FIX HERE -->
		<PackageReference Include="ModelContextProtocol" />
		<PackageReference Include="Scalar.AspNetCore" />

		<PackageReference Include="Serilog.AspNetCore" />
		<PackageReference Include="Serilog.Sinks.Console" />
		<PackageReference Include="System.Text.Json" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\ProjectName.Core\ProjectName.Core.csproj" />
		<ProjectReference Include="..\ProjectName.Contracts\ProjectName.Contracts.csproj" />
		<ProjectReference Include="..\ProjectName.Skills\ProjectName.Skills.csproj" />
		<ProjectReference Include="..\ProjectName.ServiceDefaults\ProjectName.ServiceDefaults.csproj" />
	</ItemGroup>

	<ItemGroup>
		<!-- SKILL.md must be present in output so FileAgentSkillsProvider can find it -->
		<None Update="SKILL.md">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
		<None Update="appsettings*.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>

</Project>